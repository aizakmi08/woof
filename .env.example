SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# Server-side/offline maintenance only. Never expose these in client builds.
# Use one of these when running catalog imports, analysis precompute, or
# service-key-verified catalog audits.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
PRODUCT_LOOKUP_SERVICE_KEY=your-product-lookup-service-key
ANALYZE_SERVICE_KEY=your-analyze-service-key
PRODUCT_CATALOG_SERVICE_KEY=your-catalog-audit-service-key
# Optional narrower keys for official manufacturer product-data imports.
# These can also be satisfied by PRODUCT_LOOKUP_SERVICE_KEY or a Supabase service key.
HALO_PRODUCT_IMPORT_SERVICE_KEY=your-halo-product-import-service-key
BLUEBUFFALO_PRODUCT_IMPORT_SERVICE_KEY=your-bluebuffalo-product-import-service-key
MERRICK_PRODUCT_IMPORT_SERVICE_KEY=your-merrick-product-import-service-key
WELLNESS_PRODUCT_IMPORT_SERVICE_KEY=your-wellness-product-import-service-key
CANIDAE_PRODUCT_IMPORT_SERVICE_KEY=your-canidae-product-import-service-key
HILLSPET_PRODUCT_IMPORT_SERVICE_KEY=your-hillspet-product-import-service-key
OPENFARM_PRODUCT_IMPORT_SERVICE_KEY=your-openfarm-product-import-service-key
ROYALCANIN_PRODUCT_IMPORT_SERVICE_KEY=your-royalcanin-product-import-service-key
FRESHPET_PRODUCT_IMPORT_SERVICE_KEY=your-freshpet-product-import-service-key
WERUVA_PRODUCT_IMPORT_SERVICE_KEY=your-weruva-product-import-service-key
TIKIPETS_PRODUCT_IMPORT_SERVICE_KEY=your-tikipets-product-import-service-key
PURINA_PRODUCT_IMPORT_SERVICE_KEY=your-purina-product-import-service-key
FROMM_PRODUCT_IMPORT_SERVICE_KEY=your-fromm-product-import-service-key
TASTEOFTHEWILD_PRODUCT_IMPORT_SERVICE_KEY=your-tasteofthewild-product-import-service-key
ACANA_PRODUCT_IMPORT_SERVICE_KEY=your-acana-product-import-service-key
ORIJEN_PRODUCT_IMPORT_SERVICE_KEY=your-orijen-product-import-service-key
ZIGNATURE_PRODUCT_IMPORT_SERVICE_KEY=your-zignature-product-import-service-key
NUTRIENT_PANEL_SERVICE_KEY=your-nutrient-panel-service-key
ANALYSIS_CACHE_MIGRATION_KEY=your-analysis-cache-migration-service-key
GOOGLE_WEB_CLIENT_ID=your-google-web-client-id
# RevenueCat public SDK keys from Project settings > API keys.
# iOS keys start with appl_; Android keys start with goog_.
REVENUECAT_API_KEY_IOS=appl_your-revenuecat-ios-public-sdk-key
REVENUECAT_API_KEY_ANDROID=goog_your-revenuecat-android-public-sdk-key
# Optional local Expo Go testing only. Test Store keys start with test_.
# Production validation fails if this is set for an EAS production build.
REVENUECAT_TEST_STORE_API_KEY=test_your-revenuecat-test-store-api-key
# Server-only RevenueCat sync for keeping Supabase profiles.is_pro aligned with
# App Store purchases. Configure these as Supabase Edge Function secrets only.
REVENUECAT_WEBHOOK_AUTH_TOKEN=your-long-random-webhook-bearer-token
REVENUECAT_REST_API_KEY=your-revenuecat-secret-rest-api-key
