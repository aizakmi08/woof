SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# Server-only local admin/import scripts. Never expose this as EXPO_PUBLIC_* or ship it in the app bundle.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_FUNCTIONS_BASE_URL=https://your-project.functions.supabase.co
GOOGLE_WEB_CLIENT_ID=your-google-web-client-id
REVENUECAT_API_KEY_IOS=your-revenuecat-ios-key
REVENUECAT_API_KEY_ANDROID=your-revenuecat-android-key
WOOF_SHARE_URL=https://apps.apple.com/app/id6760733899
SENTRY_DSN=your-sentry-dsn
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Optional Expo web/local smoke aliases for values that are already public in the app bundle.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=your-revenuecat-ios-key
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=your-revenuecat-android-key
EXPO_PUBLIC_WOOF_SHARE_URL=https://apps.apple.com/app/id6760733899
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn
