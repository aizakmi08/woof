{
  "expo": {
    "name": "Woof",
    "slug": "woof",
    "owner": "aizakmi08",
    "version": "1.1.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "woof",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ea14f3ad-9dbe-4341-bfba-51eb5c6ead8f"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAFA"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "io.woof.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Woof needs camera access to scan pet food packages, ingredient labels, and human foods.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#FFFFFF",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.app.woof",
      "permissions": [
        "INTERNET",
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Woof needs camera access to scan pet food packages, ingredient labels, and human foods."
        }
      ],
      "expo-apple-authentication",
      "expo-web-browser",
      "expo-sharing",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "ea14f3ad-9dbe-4341-bfba-51eb5c6ead8f"
      }
    }
  }
}
